# Setup-репозиторий хранит только общие артефакты для всех проектов.
# Проектные подпапки — локально-добавляемые, не в git.
# Whitelist: всё на верхнем уровне игнорируется, кроме явных исключений.

/*
!/.gitignore
!/Dockerfile
!/init.sh
!/connect-project.md
!/bin
!/cc-docker-proxy
!/lib
!/README.md
